@import "tailwindcss";

/* Root theme */
:root {
  --background: #0a0a0a;
  --foreground: #ffffff;
}

/* Base */
html, body {
  margin: 0;
  padding: 0;
  background: var(--background);
  color: var(--foreground);
  font-family: system-ui, -apple-system, sans-serif;
}

/* Improve text rendering */
body {
  -webkit-font-smoothing: antialiased;
}

/* Container system */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Buttons baseline */
button {
  cursor: pointer;
}

/* Fix images */
img {
  max-width: 100%;
  height: auto;
}
